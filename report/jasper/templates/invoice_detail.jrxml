<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice_detail"
              pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="f1d3ed36-1b4f-4cb4-844f-3215f1c0aa01">

    <parameter name="MaHD" class="java.lang.Integer"/>

    <queryString>
        <![CDATA[
SELECT h.MaHD,
       h.NgayLapHD,
       CONCAT(IFNULL(kh.Ho,''),' ',IFNULL(kh.Ten,'')) AS TenKhachHang,
       CONCAT(IFNULL(nv.Ho,''),' ',IFNULL(nv.Ten,'')) AS TenNhanVien,
       c.MaBanh,
       b.TenBanh,
       c.SoLuong,
       c.DonGia,
       c.ThanhTien,
       h.ThanhTien AS TongHoaDon
FROM hoadon h
JOIN chitiethoadon c ON h.MaHD = c.MaHD
LEFT JOIN banh b ON c.MaBanh = b.MaBanh
LEFT JOIN khachhang kh ON h.MaKH = kh.MaKH
LEFT JOIN nhanvien nv ON h.MaNV = nv.MaNV
WHERE h.MaHD = $P{MaHD}
ORDER BY c.MaBanh
        ]]>
    </queryString>

    <field name="MaHD" class="java.lang.Integer"/>
    <field name="NgayLapHD" class="java.sql.Timestamp"/>
    <field name="TenKhachHang" class="java.lang.String"/>
    <field name="TenNhanVien" class="java.lang.String"/>
    <field name="MaBanh" class="java.lang.Integer"/>
    <field name="TenBanh" class="java.lang.String"/>
    <field name="SoLuong" class="java.lang.Integer"/>
    <field name="DonGia" class="java.lang.Double"/>
    <field name="ThanhTien" class="java.lang.Double"/>
    <field name="TongHoaDon" class="java.lang.Double"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[PHIEU XUAT / HOA DON BAN HANG]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="35" width="555" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["Ma hoa don: " + $F{MaHD} + " | Ngay lap: " + $F{NgayLapHD}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="25">
            <textField>
                <reportElement x="0" y="0" width="280" height="20"/>
                <textFieldExpression><![CDATA["Khach hang: " + $F{TenKhachHang}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="0" width="265" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Nhan vien: " + $F{TenNhanVien}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="22">
            <staticText><reportElement x="0" y="0" width="45" height="22"/><text><![CDATA[Ma]]></text></staticText>
            <staticText><reportElement x="45" y="0" width="190" height="22"/><text><![CDATA[Ten banh]]></text></staticText>
            <staticText><reportElement x="235" y="0" width="70" height="22"/><text><![CDATA[So luong]]></text></staticText>
            <staticText><reportElement x="305" y="0" width="110" height="22"/><text><![CDATA[Don gia]]></text></staticText>
            <staticText><reportElement x="415" y="0" width="140" height="22"/><text><![CDATA[Thanh tien]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="0" y="0" width="45" height="20"/><textFieldExpression><![CDATA[$F{MaBanh}]]></textFieldExpression></textField>
            <textField><reportElement x="45" y="0" width="190" height="20"/><textFieldExpression><![CDATA[$F{TenBanh}]]></textFieldExpression></textField>
            <textField><reportElement x="235" y="0" width="70" height="20"/><textFieldExpression><![CDATA[$F{SoLuong}]]></textFieldExpression></textField>
            <textField><reportElement x="305" y="0" width="110" height="20"/><textFieldExpression><![CDATA[$F{DonGia}]]></textFieldExpression></textField>
            <textField><reportElement x="415" y="0" width="140" height="20"/><textFieldExpression><![CDATA[$F{ThanhTien}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="305" y="5" width="250" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Tong cong: " + $F{TongHoaDon}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
